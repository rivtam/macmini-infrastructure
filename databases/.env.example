# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_in_production

# Network Configuration
# Set to 127.0.0.1 in production to only expose on localhost
# Use 5432:5432 for development, 127.0.0.1:5432:5432 for production
POSTGRES_PORT=5432
POSTGRES_HOST_BINDING=${POSTGRES_HOST_BINDING:-0.0.0.0}

# Redis Configuration
REDIS_PORT=6379
REDIS_PASSWORD=changeme_in_production
REDIS_HOST_BINDING=${REDIS_HOST_BINDING:-0.0.0.0}

# For local development with different ports to avoid conflicts:
# POSTGRES_PORT=5433
# REDIS_PORT=6380

# PgBouncer Configuration
PGBOUNCER_PORT=6432

# For production (only expose to localhost):
# POSTGRES_HOST_BINDING=127.0.0.1
# REDIS_HOST_BINDING=127.0.0.1
# Applications should connect via PgBouncer (port 6432) instead of direct PostgreSQL (port 5432)
