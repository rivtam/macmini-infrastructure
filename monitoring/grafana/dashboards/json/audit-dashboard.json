{
  "dashboard": {
    "title": "Audit & Compliance Dashboard",
    "tags": ["audit", "compliance", "security"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Authentication Events (Last 24h)",
        "type": "stat",
        "datasource": "Loki",
        "targets": [
          {
            "expr": "count_over_time({log_type=\"auth_audit\"}[24h])",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Failed Login Attempts",
        "type": "stat",
        "datasource": "Loki",
        "targets": [
          {
            "expr": "count_over_time({log_type=\"auth_audit\"} |= \"Failed\" [24h])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 10, "color": "yellow"},
                {"value": 50, "color": "red"}
              ]
            }
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Database Write Operations",
        "type": "stat",
        "datasource": "Loki",
        "targets": [
          {
            "expr": "count_over_time({job=\"postgres\", log_type=\"audit\", query_type=~\"INSERT|UPDATE|DELETE\"}[24h])",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "Security Alerts",
        "type": "stat",
        "datasource": "Loki",
        "targets": [
          {
            "expr": "count_over_time({category=\"security\"}[24h])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "red"}
              ]
            }
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 5,
        "title": "Authentication Timeline",
        "type": "timeseries",
        "datasource": "Loki",
        "targets": [
          {
            "expr": "rate({log_type=\"auth_audit\"}[5m])",
            "refId": "A",
            "legendFormat": "Total Auth"
          },
          {
            "expr": "rate({log_type=\"auth_audit\"} |= \"Failed\" [5m])",
            "refId": "B",
            "legendFormat": "Failed Auth"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
      },
      {
        "id": 6,
        "title": "Database Operations by Type",
        "type": "timeseries",
        "datasource": "Loki",
        "targets": [
          {
            "expr": "rate({job=\"postgres\", log_type=\"audit\", query_type=\"SELECT\"}[5m])",
            "refId": "A",
            "legendFormat": "SELECT"
          },
          {
            "expr": "rate({job=\"postgres\", log_type=\"audit\", query_type=\"INSERT\"}[5m])",
            "refId": "B",
            "legendFormat": "INSERT"
          },
          {
            "expr": "rate({job=\"postgres\", log_type=\"audit\", query_type=\"UPDATE\"}[5m])",
            "refId": "C",
            "legendFormat": "UPDATE"
          },
          {
            "expr": "rate({job=\"postgres\", log_type=\"audit\", query_type=\"DELETE\"}[5m])",
            "refId": "D",
            "legendFormat": "DELETE"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
      },
      {
        "id": 7,
        "title": "Recent Audit Events",
        "type": "logs",
        "datasource": "Loki",
        "targets": [
          {
            "expr": "{log_type=~\".*audit.*\"}",
            "refId": "A"
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": true,
          "wrapLogMessage": true,
          "sortOrder": "Descending"
        },
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 12}
      },
      {
        "id": 8,
        "title": "Vault Access by Operation",
        "type": "piechart",
        "datasource": "Loki",
        "targets": [
          {
            "expr": "sum by (request_operation) (count_over_time({job=\"vault\", log_type=\"audit\"}[24h]))",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 22}
      },
      {
        "id": 9,
        "title": "Admin Endpoint Access",
        "type": "table",
        "datasource": "Loki",
        "targets": [
          {
            "expr": "{job=\"nginx\", log_type=\"access_audit\", path=~\"/admin.*\"}",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 16, "x": 8, "y": 22}
      },
      {
        "id": 10,
        "title": "Privileged Operations (DDL)",
        "type": "logs",
        "datasource": "Loki",
        "targets": [
          {
            "expr": "{job=\"postgres\", log_type=\"audit\", query_type=~\"CREATE|DROP|ALTER\"}",
            "refId": "A"
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": true,
          "wrapLogMessage": true,
          "sortOrder": "Descending"
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 30}
      }
    ],
    "refresh": "30s",
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    },
    "version": 1
  }
}
